{
  "action": {
    "default_icon": {
      "128": "icons/icon.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "description": "New tab page showing bookmarks and open tabs",
  "manifest_version": 3,
  "name": "Organic New Tab Page",
  "permissions": [
    "bookmarks",
    "favicon",
    "storage",
    "tabGroups",
    "tabs"
  ],
  "version": "1.0"
}